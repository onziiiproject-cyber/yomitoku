// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CompanyStatus {
  PENDING_PAYMENT
  ACTIVE
  PAST_DUE
  CANCELED
}

model Company {
  id           String        @id @default(cuid())
  name         String // 法人名
  facilityName String? // 事業所名
  contactName  String
  contactRole  String?
  phone        String?
  prefecture   String?
  email        String        @unique
  passwordHash String?
  status       CompanyStatus @default(PENDING_PAYMENT)

  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  // Issued only once payment succeeds — an unpaid signup never has a usable invite code.
  inviteCode String? @unique

  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?
  lastLoginAt         DateTime?

  maxRecipients Int @default(3)

  // 無料期間（紹介登録時のみ設定）
  trialEndsAt           DateTime?
  trialReminder7dSentAt DateTime?
  trialReminder1dSentAt DateTime?

  // 紹介まわり
  referredByCodeId String?
  referredByCode   ReferralCode? @relation("ReferredByCode", fields: [referredByCodeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tags            CompanyTag[]
  lineRecipients  LineRecipient[]
  users           User[]
  messageSends    MessageSend[]
  favorites       Favorite[]
  articleReads    ArticleRead[]
  articleLikes    ArticleLike[]
  articleComments ArticleComment[]
  commentLikes    CommentLike[]
  articleReports  ArticleReport[]
}

// 本部が発行するキャンペーン単位の紹介コード（特定事業所に紐づかない）。
// 例:「〇〇協会加盟者用」「地元地域施設運営者用」のように配布先グループ単位で発行する。
model ReferralCode {
  id           String    @id @default(cuid())
  code         String    @unique
  label        String
  expiresAt    DateTime?
  // trueの場合、このコードでの登録はStripe決済をスキップし即アクティブ化する（アンバサダー登録用）
  isAmbassador Boolean   @default(false)
  createdAt    DateTime  @default(now())

  referredCompanies Company[] @relation("ReferredByCode")
}

model Tag {
  id        String @id @default(cuid())
  key       String @unique
  label     String
  sortOrder Int    @default(0)

  companies CompanyTag[]
  users     UserTag[]
}

model CompanyTag {
  companyId String
  tagId     String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([companyId, tagId])
}

model LineRecipient {
  id           String    @id @default(cuid())
  companyId    String
  lineUserId   String    @unique
  displayName  String?
  nickname     String?
  followedAt   DateTime  @default(now())
  unfollowedAt DateTime?

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messageSends MessageSend[]
  user         User?
}

// 会社に紐づく「個人」。人数制限なし（LINE連携は任意でLineRecipientと1:1）。
// BASEでの表示名・タグの好み（UserTag）の単位で、LINEリッチメニューとWEBの両方から同じデータを編集できる。
model User {
  id              String   @id @default(cuid())
  companyId       String
  name            String
  lineRecipientId String?  @unique
  iconKey         String?
  iconUrl         String?
  createdAt       DateTime @default(now())

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lineRecipient LineRecipient? @relation(fields: [lineRecipientId], references: [id], onDelete: SetNull)
  tags          UserTag[]
}

model UserTag {
  userId String
  tagId  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([userId, tagId])
}

enum WebhookSource {
  STRIPE
  LINE
}

model WebhookEvent {
  id              String        @id @default(cuid())
  source          WebhookSource
  externalEventId String
  type            String
  payload         String
  receivedAt      DateTime      @default(now())
  processedAt     DateTime?

  @@unique([source, externalEventId])
}

enum MessageBatchKind {
  WEEKLY_DIGEST
  BREAKING_NEWS
  MANUAL_TEST
}

model MessageBatch {
  id             String           @id @default(cuid())
  kind           MessageBatchKind
  title          String
  content        String
  idempotencyKey String           @unique
  createdAt      DateTime         @default(now())

  sends     MessageSend[]
  documents BatchDocument[]
}

model SiteDocument {
  id             String    @id @default(cuid())
  url            String
  // 分科会は1URL（1回の会合）から複数トピックの記事を作るため、themeNoで区別する。
  // mhlw_latestは常に0（実質1URL=1記事のまま）。
  themeNo        Int       @default(0)
  title          String
  source         String // "mhlw_latest" | "shingi"
  publishedAt    DateTime?
  rawText        String    @db.Text
  summary        String?   @db.Text
  tags           String[]
  importance     String    @default("normal") // "high" | "normal"
  // 議論中("discussion")か決定事項("decided")かのAI分類。どちらにも当てはまらない場合はnull（バッジ非表示）
  decisionStatus String?
  processedAt    DateTime?
  createdAt      DateTime  @default(now())

  structuredContent Json?

  batches         BatchDocument[]
  favorites       Favorite[]
  reads           ArticleRead[]
  likes           ArticleLike[]
  comments        ArticleComment[]
  reports         ArticleReport[]
  podcastEpisodes PodcastEpisode[]

  @@unique([url, themeNo])
}

model BatchDocument {
  messageBatchId String
  siteDocumentId String

  messageBatch MessageBatch @relation(fields: [messageBatchId], references: [id], onDelete: Cascade)
  siteDocument SiteDocument @relation(fields: [siteDocumentId], references: [id], onDelete: Cascade)

  @@id([messageBatchId, siteDocumentId])
}

enum MessageSendStatus {
  PENDING
  SENT
  FAILED
  SKIPPED_UNPAID
  SKIPPED_UNFOLLOWED
}

model MessageSend {
  id              String  @id @default(cuid())
  messageBatchId  String
  companyId       String
  lineRecipientId String?

  status         MessageSendStatus @default(PENDING)
  lineResponseId String?
  sentAt         DateTime?
  error          String?

  messageBatch  MessageBatch   @relation(fields: [messageBatchId], references: [id], onDelete: Cascade)
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lineRecipient LineRecipient? @relation(fields: [lineRecipientId], references: [id], onDelete: Cascade)

  @@unique([messageBatchId, lineRecipientId])
}

model Favorite {
  companyId      String
  siteDocumentId String
  createdAt      DateTime @default(now())

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  siteDocument SiteDocument @relation(fields: [siteDocumentId], references: [id], onDelete: Cascade)

  @@id([companyId, siteDocumentId])
}

model ArticleRead {
  companyId      String
  siteDocumentId String
  createdAt      DateTime @default(now())

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  siteDocument SiteDocument @relation(fields: [siteDocumentId], references: [id], onDelete: Cascade)

  @@id([companyId, siteDocumentId])
}

model ArticleLike {
  companyId      String
  siteDocumentId String
  createdAt      DateTime @default(now())

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  siteDocument SiteDocument @relation(fields: [siteDocumentId], references: [id], onDelete: Cascade)

  @@id([companyId, siteDocumentId])
}

model ArticleComment {
  id              String   @id @default(cuid())
  companyId       String?
  siteDocumentId  String
  authorName      String
  authorIconKey   String?
  authorIconUrl   String?
  body            String   @db.Text
  isEditorComment Boolean  @default(false)
  createdAt       DateTime @default(now())

  company      Company?      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  siteDocument SiteDocument  @relation(fields: [siteDocumentId], references: [id], onDelete: Cascade)
  commentLikes CommentLike[]
}

model CommentLike {
  companyId String
  commentId String
  createdAt DateTime @default(now())

  company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  comment ArticleComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([companyId, commentId])
}

enum PodcastEpisodeStatus {
  DRAFT // 台本・音声は生成済みだが未レビュー
  PUBLISHED // 承認済み、RSSフィードに反映される
  REJECTED // 見送り
}

// ヨミトク放送室（ゴリ編集長×ミスグレーの音声コンテンツ）のエピソード。
// PUBLISHEDのものだけがRSSフィード（/podcast/feed.xml）に載る。
model PodcastEpisode {
  id          String               @id @default(cuid())
  title       String
  description String               @db.Text
  script      Json // ダイアログ台本（[{speaker, text}]）。レビュー画面での表示用
  audioUrl    String // Vercel Blob上のmp3 URL
  durationSec Int
  status      PodcastEpisodeStatus @default(DRAFT)
  publishedAt DateTime? // RSS pubDateに使う。PUBLISHEDになった時点でセット
  createdAt   DateTime             @default(now())

  sourceDocId String?
  sourceDoc   SiteDocument? @relation(fields: [sourceDocId], references: [id], onDelete: SetNull)
}

// 記事の内容についての誤り・わかりにくさの報告（ユーザーによる分散QA）
model ArticleReport {
  id             String   @id @default(cuid())
  companyId      String
  siteDocumentId String
  category       String
  body           String?  @db.Text
  createdAt      DateTime @default(now())

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  siteDocument SiteDocument @relation(fields: [siteDocumentId], references: [id], onDelete: Cascade)
}
